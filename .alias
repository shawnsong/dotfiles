awscred() {
  cat $(ll -t ~/.aws/cli/cache | sed -n '2 p' | awk '{print "/Users/shawnsong/.aws/cli/cache/"$NF}') | jq .Credentials
}


cdf() {
   local file
   local dir
   file=$(fzf +m -q "$1") && dir=$(dirname "$file") && cd "$dir"
}

cdg() {
  cd $(git rev-parse --show-toplevel)
}

is_in_git_repo() {
  git rev-parse HEAD > /dev/null 2>&1
}

__gitbranchsel() {
  local cmd="is_in_git_repo && git branch"
  setopt localoptions pipefail no_aliases 2> /dev/null
  local item
  eval "$cmd" | FZF_DEFAULT_OPTS="--height ${FZF_TMUX_HEIGHT:-40%} --reverse --bind=ctrl-z:ignore $FZF_DEFAULT_OPTS $FZF_CTRL_T_OPTS" $(__fzfcmd) "$@" | while read item; do
    echo -n "${(q)item} " | sed -e 's/\\\*\\//' | sed -e 's/\ //g '
  done
  local ret=$?
  echo
  return $ret
}


fzf-git-branch-widget() {
  LBUFFER="${LBUFFER}$(__gitbranchsel)"
  local ret=$?
  zle reset-prompt
  return $ret
}
zle     -N   fzf-git-branch-widget
bindkey '^B' fzf-git-branch-widget

