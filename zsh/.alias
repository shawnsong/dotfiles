alias vi='nvim'

# OS-specific ls colors
if [[ "$OSTYPE" == "darwin"* ]]; then
  alias ls='ls -G'
  alias ll='ls -lG'
else
  alias ls='ls --color=auto'
  alias ll='ls -l --color=auto'
fi

function git_commit(){ git commit -m "$*"; }
alias tgz='tar -zxvf'
alias tbz='tar -jxvf'

alias p='python3'

alias grep='grep --color=auto'

# Docker
alias dcup='docker-compose up'
alias dcd='docker-compose down'
alias dcl='docker-compose logs -f'
alias dps='docker ps'
alias dimgs='docker images'
alias dex='docker exec -it '

# Git
alias giad='git add'
alias gick='git checkout'
alias gicm=git_commit
alias gist='git status'
alias gips='git push'
alias gipssu='git push --set-upstream origin '
alias gipl='git pull'
alias giplom='git pull origin master'
alias giplog='git pull origin green'
alias gidf='git diff'
# alias giaa='git add --all'
alias gibr='git branch'
alias gfom='git fetch origin master:master'
alias gfog='git fetch origin green:green'
alias gimm='git merge master'
alias gimg='git merge green'


# Build tools
alias mci="mvn clean install"
alias mcist="mvn clean install -DskipTests"

alias ra='ranger'

alias uuidgen='uuidgen | tr "[:upper:]" "[:lower:]"'

